# ─── Server ─────────────────────────────────────────────────────
PORT=3123
NODE_ENV=development

# ─── MongoDB (required) ────────────────────────────────────────
# Use the docker compose default if you brought the stack up locally:
#   mongodb://kraviona:kraviona_dev_pw@localhost:27017/kraviona
# Or, if you run mongod without auth (e.g. `mongod --dbpath ./data`):
#   mongodb://localhost:27017/
# Production (Atlas):
#   mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb://kraviona:kraviona_dev_pw@localhost:27017/kraviona
MONGODB_DB_NAME=kraviona

# ─── JWT (required) ────────────────────────────────────────────
# Generate a strong secret with:  openssl rand -base64 64
JWT_SECRET_KEY=replace_with_a_long_random_secret_at_least_32_chars

# ─── CORS (soft, defaults shown) ───────────────────────────────
FRONTEND_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:3001
BACKENDAPI_CORS=http://localhost:5000

# ─── Redis (optional - falls back to in-memory cache) ──────────
# Set to enable real Redis caching; leave unset to use the in-memory layer.
# REDIS_URL=redis://localhost:6379

# ─── Cloudinary (only required when an upload route is hit) ────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (Resend preferred, Gmail fallback) ───────────────────
# Get a Resend key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Kraviona <noreply@kraviona.com>
SUPPORT_EMAIL=kravionatech@gmail.com

# Gmail fallback creds (Nodemailer). Leave blank unless you actually
# want to send mail - the Resend path is preferred.
GMAIL_USER_EMAIL=
GMAIL_APP_PASSWORD=

# ─── Seed control ──────────────────────────────────────────────
# Set to 1 to skip the automatic site seed on backend boot.
# Useful when running manual data migrations.
SKIP_SITE_SEED=0
